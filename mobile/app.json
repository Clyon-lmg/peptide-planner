{
  "expo": {
    "name": "Peptide Planner",
    "slug": "peptideplanner",
    "owner": "peptideplanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.peptideplanner.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "We send dose reminders at your scheduled injection times."
      }
    },
    "android": {
      "package": "com.peptideplanner.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "packagingOptions": {
              "pickFirsts": ["lib/**/libworklets.so"]
            }
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366f1",
          "sounds": []
        }
      ]
    ],
    "scheme": "peptideplanner",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "46874ec7-578d-42d9-8c77-d2d4a54ce009"
      }
    }
  }
}
